{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "moduleSuffixes": [".ui", ""],
    "paths": {
      "@/*": ["src/*"],
      "@assets/*": ["assets/*"]
    }
  },
  "include": [
    "entrypoint.js",
    "app",
    "src",
    "app.config.ts",
    "metro.config.js",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
